#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

if command -v python >/dev/null 2>&1; then
  exec python scripts/sanitize_staged_secrets.py
fi

if command -v py >/dev/null 2>&1; then
  exec py -3 scripts/sanitize_staged_secrets.py
fi

if command -v python3 >/dev/null 2>&1; then
  exec python3 scripts/sanitize_staged_secrets.py
fi

echo "Python 3 is required to run the staged secret sanitizer." >&2
exit 1
