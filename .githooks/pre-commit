#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

run_node_script() {
  script_path=$1

  if command -v node >/dev/null 2>&1; then
    node "$script_path"
    return
  fi

  echo "Node.js is required to run git hooks." >&2
  exit 1
}

run_node_script "scripts/sanitize-staged-secrets.mjs"
run_node_script "scripts/check-spec-sync.mjs"
