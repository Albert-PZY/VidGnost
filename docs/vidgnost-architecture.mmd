flowchart LR
  %% =========================
  %% VidGnost 系统架构图
  %% =========================

  subgraph FE["Frontend（Vite + React + TypeScript）"]
    FE1["App.tsx（状态中枢）"]
    FE2["Task Hooks：task-manager / task-stream / event-handler"]
    FE3["Runtime 组件：WorkbenchRuntimeMain / Panels / Modals"]
    FE4["API Client：frontend/src/lib/api.ts"]
    FE5["SSE Client：EventSource(useTaskEvents)"]
    FE6["Self-Check Hooks：useSelfCheck / useSelfCheckEvents"]
  end

  subgraph GW["Backend Gateway（FastAPI）"]
    GW1["main.py：lifespan 装配依赖"]
    GW2["routes_tasks：任务、SSE、导出、重跑D"]
    GW3["routes_config：LLM/Whisper/Prompt 配置"]
    GW4["routes_self_check：自检与自动修复"]
    GW5["routes_health：健康检查"]
  end

  subgraph ORCH["Orchestration（应用编排层）"]
    O1["TaskRunner：A/B/C/D 主流水线"]
    O2["ModelRuntimeManager：GPU 运行时租约与驱逐"]
    O3["ResourceGuard：容量校验与配置守卫"]
    O4["SelfCheckService：环境自检与脚本修复"]
  end

  subgraph CORE["Domain Services（核心能力层）"]
    C1["Ingestion：yt-dlp 下载 + 本地文件准备"]
    C2["Audio Pipeline：ffmpeg 提取 + WAV 切块"]
    C3["WhisperService：faster-whisper 转写与模型缓存"]
    C4["LLMService：转写优化、摘要、导图、Mermaid 修复"]
    C5["Exporters：Markmap HTML 与归档导出"]
  end

  subgraph STORE["State & Config Stores（状态与配置）"]
    S1["TaskStore：任务记录/阶段指标/告警/分析结果"]
    S2["StageArtifactStore：阶段产物文件"]
    S3["EventBus：内存历史 + 订阅队列 + trace_id"]
    S4["RuntimeConfigStore：Whisper config.toml"]
    S5["LLMConfigStore：model_config.json"]
    S6["PromptTemplateStore：prompts/templates + selection"]
  end

  subgraph FS["Persistence Layout（文件系统持久化）"]
    F1["storage/tasks/records/*.json"]
    F2["storage/tasks/stage-artifacts/{task_id}/..."]
    F3["storage/tasks/stage-metrics + runtime-warnings + analysis-results"]
    F4["storage/event-logs/{task_id}.jsonl"]
    F5["storage/runtime/config.toml"]
    F6["storage/model_config.json"]
    F7["storage/prompts/templates/*.json + selection.json"]
    F8["storage/model-hub/faster-whisper-small/*"]
  end

  subgraph EXT["External Systems（外部系统）"]
    X1["Bilibili 视频源"]
    X2["本地视频文件/上传文件"]
    X3["ffmpeg 二进制"]
    X4["hf-mirror.com / huggingface.co"]
    X5["OpenAI 兼容 LLM API"]
    X6["浏览器端 SSE 连接"]
    X7["PowerShell/Bash 自检修复脚本"]
  end

