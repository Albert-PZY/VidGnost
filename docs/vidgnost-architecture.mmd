flowchart TB
  %% ==========================================
  %% VidGnost 系统架构图（优化版）
  %% 分层目标：前端 -> API -> 编排 -> 核心服务 -> 存储 -> 持久化
  %% ==========================================

  subgraph GUIDE["阅读指引"]
    direction TB
    G1["① 自上而下看主层级：请求如何落到后端执行"]
    G2["② 再看左右两侧：SSE 实时回流、外部依赖调用"]
    G3["③ 最后看底层：哪些目录持久化了任务与配置"]
  end

  subgraph L1["L1 前端层（React + Vite）"]
    direction LR
    FE1["App.tsx（状态中枢）"]
    FE2["Task Hooks（manager/stream/event-handler）"]
    FE3["Runtime 组件（WorkbenchRuntimeMain 等）"]
    FE4["API Client（frontend/src/lib/api.ts）"]
    FE5["SSE Client（useTaskEvents/EventSource）"]
    FE6["Self-Check Hooks（useSelfCheck）"]
  end

  subgraph L2["L2 API 网关层（FastAPI Routers）"]
    direction LR
    GW0["main.py（lifespan 注入依赖）"]
    GW1["routes_tasks（任务/SSE/导出/重跑D）"]
    GW2["routes_config（LLM/Whisper/Prompt 配置）"]
    GW3["routes_self_check（自检/自动修复）"]
    GW4["routes_health（健康检查）"]
  end

  subgraph L3["L3 编排与协调层"]
    direction LR
    O1["TaskRunner（A/B/C/D 主流水线）"]
    O2["ModelRuntimeManager（运行时租约与驱逐）"]
    O3["ResourceGuard（资源与配置守卫）"]
    O4["SelfCheckService（环境诊断与修复编排）"]
  end

  subgraph L4["L4 核心服务层"]
    direction LR
    C1["Ingestion（yt-dlp/本地文件准备）"]
    C2["Audio Pipeline（ffmpeg 提取 + WAV 切块）"]
    C3["WhisperService（转写 + 模型缓存）"]
    C4["LLMService（转录优化/摘要/导图）"]
    C5["Exporters（Markmap HTML/归档导出）"]
  end

  subgraph L5["L5 状态与配置存储层"]
    direction LR
    S1["TaskStore（records/stage_metrics/runtime_warnings）"]
    S2["StageArtifactStore（阶段产物文件）"]
    S3["EventBus（history + queue + trace_id）"]
    S4["RuntimeConfigStore（config.toml）"]
    S5["LLMConfigStore（model_config.json）"]
    S6["PromptTemplateStore（templates + selection）"]
  end

  subgraph L6["L6 文件持久化层"]
    direction LR
    F1["storage/tasks/records/*.json"]
    F2["storage/tasks/stage-artifacts/{task_id}/..."]
    F3["storage/tasks/stage-metrics + runtime-warnings + analysis-results"]
    F4["storage/event-logs/{task_id}.jsonl"]
    F5["storage/runtime/config.toml"]
    F6["storage/model_config.json"]
    F7["storage/prompts/templates/*.json + selection.json"]
    F8["storage/model-hub/faster-whisper-small/*"]
  end

  subgraph EXT["外部系统与运行时依赖"]
    direction LR
    X1["Bilibili 视频源"]
    X2["本地文件/上传文件"]
    X3["ffmpeg 程序"]
    X4["hf-mirror / huggingface"]
    X5["OpenAI 兼容 LLM API"]
    X6["浏览器 SSE 长连接"]
    X7["PowerShell/Bash 自检修复脚本"]
  end

