flowchart TB
  %% ==========================================
  %% VidGnost 端到端流程图（优化版）
  %% 设计目标：主链清晰、排线可读、便于 Draw.io 导入
  %% ==========================================

  subgraph GUIDE["阅读指引"]
    direction TB
    G1["① 先看中间主链：从任务提交到任务结束"]
    G2["② 再看左侧阶段细化：A/B/C/D 各做什么"]
    G3["③ 最后看右侧：SSE 回流、终态操作、重跑 D"]
  end

  subgraph MAIN["主执行链（中轴）"]
    direction TB
    M1["前端提交任务（url/path/upload）"]
    M2["routes_tasks 创建 TaskRecord（queued）"]
    M3["TaskRunner.submit -> _run_pipeline"]
    M4["阶段 A：视频源接入与准备"]
    M5["阶段 B：提取音频并切块"]
    M6["阶段 C：Whisper 转写"]
    M7["阶段 D：转录优化 + 融合交付"]
    M8["任务结束（completed/failed/cancelled）"]
  end

  subgraph DETAIL["阶段细化（左侧）"]
    direction TB
    A1["A-1：Bilibili 下载（yt-dlp）或本地文件准备"]
    B1["B-1：extract_audio_wav（ffmpeg）"]
    B2["B-2：split_audio_wav（chunk_XXXX.wav）"]
    C1["C-1：读取 Whisper 配置（RuntimeConfigStore）"]
    C2["C-2：ensure_small_model_ready（自动下载模型）"]
    C3["C-3：按 chunk 转写（WhisperService.transcribe）"]
    C4["C-4：聚合 transcript_text + transcript_segments"]
    D1["D-1：读取 LLM 配置与 Prompt 模板"]
    D2["D-2：substage transcript_optimize（off/strict/rewrite）"]
    D3["D-3：substage fusion_delivery（summary/mindmap/notes）"]
    D4["D-4：生成 artifact_index_json + artifact_total_bytes"]
  end

  subgraph SIDEFX["每阶段共同行为（A/B/C/D 都会触发）"]
    direction TB
    P0["阶段钩子（统一副作用入口）"]
    P1["TaskStore：更新状态/进度/日志/stage_metrics"]
    P2["StageArtifactStore：写入阶段产物"]
    P3["EventBus.publish：stage/progress/log/delta"]
  end

  subgraph SSE["事件回流到前端（右侧）"]
    direction TB
    E1["EventBus：history + subscriber queue"]
    E2["GET /api/tasks/{id}/events（SSE）"]
    E3["useTaskEvents：EventSource 订阅"]
    E4["useWorkbenchTaskEventHandler：事件解析"]
    E5["useTaskStream：缓冲刷新日志与文本"]
    E6["WorkbenchRuntimeMain：渲染实时面板"]
    E7["event-logs/{task_id}.jsonl（事件落盘）"]
  end

  subgraph AFTER["终态与后续操作（右下）"]
    direction TB
    T1["PATCH /api/tasks/{id}/artifacts（编辑摘要/导图）"]
    T2["GET /api/tasks/{id}/export/{kind}（导出）"]
    T3["POST /api/tasks/{id}/rerun-stage-d（重跑 D）"]
    T4["_run_stage_d_retry：仅重做 D 子阶段"]
  end

  subgraph EXT["外部依赖"]
    direction TB
    X1["Bilibili 视频源"]
    X2["ffmpeg 可执行程序"]
    X3["hf-mirror / huggingface（Whisper 模型）"]
    X4["OpenAI 兼容 LLM API"]
  end

  subgraph FRONTEND["前端核心模块"]
    direction TB
    F1["App.tsx：状态中枢"]
    F2["useWorkbenchTaskManager：提交/取消/重跑D"]
    F3["frontend/src/lib/api.ts：HTTP API 封装"]
  end

  M1 --> M2 --> M3 --> M4 --> M5 --> M6 --> M7 --> M8
  F1 --> F2 --> F3 --> M1

  M4 --> A1
  M5 --> B1 --> B2
  M6 --> C1 --> C2 --> C3 --> C4
  M7 --> D1 --> D2 --> D3 --> D4

  A1 --> X1
  B1 --> X2
  C2 --> X3
  D3 --> X4

  M4 --> P0
  M5 --> P0
  M6 --> P0
  M7 --> P0
  P0 --> P1
  P0 --> P2
  P0 --> P3

  P3 --> E1 --> E2 --> E3 --> E4 --> E5 --> E6
  E1 --> E7
  M8 --> E1

  M8 --> T1
  M8 --> T2
  M8 --> T3 --> T4 --> M7
  T1 --> P1

  classDef guide fill:#F3F4F6,stroke:#4B5563,color:#111827,stroke-width:1.2px;
  classDef main fill:#E6F7FF,stroke:#0C7FB0,color:#073042,stroke-width:1.5px;
  classDef detail fill:#EAFBE7,stroke:#2E7D32,color:#123B17,stroke-width:1.2px;
  classDef sidefx fill:#FFF4E5,stroke:#C56A00,color:#4A2A00,stroke-width:1.2px;
  classDef event fill:#FFE7F1,stroke:#C2185B,color:#5B1030,stroke-width:1.2px;
  classDef after fill:#FFEDEA,stroke:#D84315,color:#5B1E0E,stroke-width:1.2px;
  classDef external fill:#FFFDE7,stroke:#AF8F00,color:#4B3B00,stroke-width:1.2px;
  classDef frontend fill:#EEF2FF,stroke:#4F46E5,color:#1E1B4B,stroke-width:1.2px;

  class G1,G2,G3 guide;
  class M1,M2,M3,M4,M5,M6,M7,M8 main;
  class A1,B1,B2,C1,C2,C3,C4,D1,D2,D3,D4 detail;
  class P0,P1,P2,P3 sidefx;
  class E1,E2,E3,E4,E5,E6,E7 event;
  class T1,T2,T3,T4 after;
  class X1,X2,X3,X4 external;
  class F1,F2,F3 frontend;
